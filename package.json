{
  "name": "ts-object-visualizer",
  "displayName": "TS Object Visualizer",
  "description": "Visualize TypeScript classes, interfaces and type aliases as interactive node graphs — with full deep inheritance resolution.",
  "version": "0.2.1",
  "publisher": "51p50x",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/51p50x/ts-visualizer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "typescript",
    "visualizer",
    "inheritance",
    "class",
    "interface",
    "graph"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsVisualizer.visualizeType",
        "title": "TS Visualizer: Visualize Type"
      },
      {
        "command": "tsVisualizer.exportJson",
        "title": "TS Visualizer: Export as JSON"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tsVisualizer.visualizeType",
          "when": "editorLangId =~ /typescript|typescriptreact/",
          "group": "navigation@100"
        },
        {
          "command": "tsVisualizer.exportJson",
          "when": "editorLangId =~ /typescript|typescriptreact/",
          "group": "navigation@101"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tsVisualizer.visualizeType",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId =~ /typescript|typescriptreact/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "webpack --mode production --config webpack.config.js",
    "build:webview": "webpack --mode production --config webpack.webview.config.js",
    "watch": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "watch:ext": "webpack --mode development --watch --config webpack.config.js",
    "watch:webview": "webpack --mode development --watch --config webpack.webview.config.js",
    "compile": "npm run build:ext && npm run build:webview",
    "lint": "eslint src --ext ts,tsx",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/vscode": "^1.85.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.9.1",
    "jest": "^29.7.0",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@xyflow/react": "^12.4.0",
    "html-to-image": "^1.11.11",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4",
    "ts-morph": "^21.0.1"
  }
}
